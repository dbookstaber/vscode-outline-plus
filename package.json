{
  "private": true,
  "author": {
    "name": "David Bookstaber",
    "email": "bookstaber@gmail.com"
  },
  "publisher": "DavidBookstaber",
  "name": "outline-regions-plus",
  "displayName": "Outline++ (Regions & Colors)",
  "description": "Outline++: navigate code regions and document outlines with color-coded modifier icons.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbookstaber/vscode-outline-plus.git"
  },
  "homepage": "https://github.com/dbookstaber/vscode-outline-plus#readme",
  "bugs": {
    "url": "https://github.com/dbookstaber/vscode-outline-plus/issues"
  },
  "galleryBanner": {
    "color": "#00002e",
    "theme": "dark"
  },
  "icon": "assets/icon.png",
  "license": "GPL-3.0-only",
  "version": "1.0.2",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "outline++",
    "outline-plus",
    "outline",
    "regions",
    "region",
    "symbols",
    "document-symbols",
    "navigation",
    "code-navigation",
    "tree-view",
    "code-structure"
  ],
  "activationEvents": [
    "onLanguage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "outlinePlus.goToRegionBoundary",
        "title": "Outline++: Go to Region Boundary"
      },
      {
        "command": "outlinePlus.selectCurrentRegion",
        "title": "Outline++: Select Current Region"
      },
      {
        "command": "outlinePlus.goToRegionFromQuickPick",
        "title": "Outline++: Go to Region..."
      },
      {
        "command": "outlinePlus.goToNextRegion",
        "title": "Outline++: Go to Next Region"
      },
      {
        "command": "outlinePlus.goToPreviousRegion",
        "title": "Outline++: Go to Previous Region"
      },
      {
        "command": "outlinePlus.regionsView.hide",
        "title": "Outline++: Hide Regions View",
        "when": "config.outlinePlus.regionsView.isVisible"
      },
      {
        "command": "outlinePlus.regionsView.show",
        "title": "Outline++: Show Regions View",
        "when": "!config.outlinePlus.regionsView.isVisible"
      },
      {
        "command": "outlinePlus.regionsView.resetAutoHidePreference",
        "title": "Outline++: Reset Regions View Auto-Hide Preference"
      },
      {
        "command": "outlinePlus.fullOutlineView.hide",
        "title": "Outline++: Hide Full Outline View",
        "when": "config.outlinePlus.fullOutlineView.isVisible"
      },
      {
        "command": "outlinePlus.fullOutlineView.show",
        "title": "Outline++: Show Full Outline View",
        "when": "!config.outlinePlus.fullOutlineView.isVisible"
      },
      {
        "command": "outlinePlus.regionsView.stopAutoHighlightingActiveRegion",
        "title": "Outline++: Regions View: Stop Auto-Highlighting Active Region",
        "when": "config.outlinePlus.regionsView.shouldAutoHighlightActiveRegion",
        "icon": "$(sync)"
      },
      {
        "command": "outlinePlus.regionsView.startAutoHighlightingActiveRegion",
        "title": "Outline++: Regions View: Start Auto-Highlighting Active Region",
        "when": "!config.outlinePlus.regionsView.shouldAutoHighlightActiveRegion",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "outlinePlus.fullOutlineView.stopAutoHighlightingActiveItem",
        "title": "Outline++: Full Outline View: Stop Auto-Highlighting Active Item",
        "when": "config.outlinePlus.fullOutlineView.shouldAutoHighlightActiveItem",
        "icon": "$(sync)"
      },
      {
        "command": "outlinePlus.fullOutlineView.startAutoHighlightingActiveItem",
        "title": "Outline++: Full Outline View: Start Auto-Highlighting Active Item",
        "when": "!config.outlinePlus.fullOutlineView.shouldAutoHighlightActiveItem",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "outlinePlus.regionsView.expandAll",
        "title": "Outline++: Regions View: Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "outlinePlus.fullOutlineView.expandAll",
        "title": "Outline++: Full Outline View: Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "outlinePlus.regionsView.refresh",
        "title": "Outline++: Refresh Regions View",
        "icon": "$(refresh)"
      },
      {
        "command": "outlinePlus.fullOutlineView.refresh",
        "title": "Outline++: Refresh Full Outline",
        "icon": "$(refresh)"
      },
      {
        "command": "outlinePlus.showDebugLog",
        "title": "Outline++: Show Debug Log"
      },
      {
        "command": "outlinePlus.dumpDiagnosticState",
        "title": "Outline++: Dump Diagnostic State"
      }
    ],
    "configuration": [
      {
        "title": "Outline++",
        "order": 0,
        "properties": {
          "outlinePlus.regionBoundaryPatternByLanguageId": {
            "type": "object",
            "description": "Regular expression strings to match region boundaries for different languages.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "startRegex": {
                  "description": "JS-format regular expression string (or array of regex strings) to match the start of a region. Should ideally include a capturing group for the region name.",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                },
                "endRegex": {
                  "description": "JS-format regular expression string (or array of regex strings) to match the end of a region.",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                }
              },
              "required": [
                "startRegex",
                "endRegex"
              ]
            },
            "default": {
              "c": {
                "startRegex": "^\\s*\\/\\/\\s*#region(?:\\s+(.*?)\\s*)?$",
                "endRegex": "^\\s*\\/\\/\\s*#endregion(?:\\s.*)?$"
              },
              "clojure": {
                "startRegex": "^\\s*;+\\s*#region(?:\\s+(.*?)\\s*)?$",
                "endRegex": "^\\s*;+\\s*#endregion(?:\\s.*)?$"
