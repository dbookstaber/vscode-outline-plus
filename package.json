      {
        "title": "Regions View",
        "order": 1,
        "properties": {
          "outlinePlus.regionsView.isVisible": {
            "type": "boolean",
            "default": true,
            "description": "Show the Regions view."
          },
          "outlinePlus.regionsView.shouldAutoHide": {
            "type": "boolean",
            "default": true,
            "description": "Automatically hide the Regions view when the active document has no regions, and show it when switching to a document with regions."
          },
          "outlinePlus.regionsView.shouldAutoHighlightActiveRegion": {
            "type": "boolean",
            "default": true,
            "description": "Automatically reveal and highlight the cursor's active region in the Regions view."
          }
        }
      },
      {
        "title": "Full Outline View",
        "order": 2,
        "properties": {
          "outlinePlus.fullOutlineView.isVisible": {
            "type": "boolean",
            "default": true,
            "description": "Show the Full Outline view."
          },
          "outlinePlus.fullOutlineView.shouldAutoHighlightActiveItem": {
            "type": "boolean",
            "default": true,
            "description": "Automatically reveal and highlight the cursor's active region/symbol in the Full Outline view."
          },
          "outlinePlus.fullOutlineView.modifierDisplay": {
            "type": "string",
            "enum": [
              "off",
              "colorOnly",
              "colorAndBadge",
              "colorAndSvgOverlay",
              "colorAndDescription"
            ],
            "enumDescriptions": [
              "Do not show symbol modifiers",
              "Show visibility modifiers using icon colors only",
              "Show visibility using icon colors + badge symbols next to icon (🔒 S etc.)",
              "Show visibility using icon colors + custom SVG icons with overlay badges (method/property/field only)",
              "Show visibility using icon colors + text descriptions to the right"
            ],
            "default": "colorAndBadge",
            "description": "Controls how symbol modifiers (visibility: public/private/protected, static, readonly, etc.) are displayed in the Full Outline view."
          },
          "outlinePlus.fullOutlineView.useDistinctModifierColors": {
            "type": "boolean",
            "default": true,
            "description": "Use distinct colors (green=public, red=private, yellow=protected) for visibility modifiers. When disabled, uses more subtle symbol-themed colors."
          }
        }
      },
      {
        "title": "Outline++: Debug",
        "order": 3,
        "properties": {
          "outlinePlus.enableDebugLogging": {
            "type": "boolean",
            "default": false,
            "description": "Enable debug logging to the 'Outline++' output channel. Useful for diagnosing issues with outline refresh or editor tracking."
          }
        }
      }
    ],
    "keybindings": [
      {
        "command": "outlinePlus.goToRegionBoundary",
        "key": "alt+m",
        "when": "editorTextFocus"
      },
      {
        "command": "outlinePlus.selectCurrentRegion",
        "key": "alt+shift+m",
        "when": "editorTextFocus"
      },
      {
        "command": "outlinePlus.goToRegionFromQuickPick",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus"
      },
      {
        "command": "outlinePlus.goToNextRegion",
        "key": "ctrl+alt+n",
        "when": "editorTextFocus"
      },
      {
        "command": "outlinePlus.goToPreviousRegion",
        "key": "ctrl+alt+p",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "outlinePlus.regionsView.refresh",
          "when": "view == outlinePlusRegionsView",
          "group": "navigation@0"
        },
        {
          "command": "outlinePlus.fullOutlineView.refresh",
          "when": "view == outlinePlusFullTreeView",
          "group": "navigation@0"
        },
        {
          "command": "outlinePlus.regionsView.stopAutoHighlightingActiveRegion",
          "when": "view == outlinePlusRegionsView && config.outlinePlus.regionsView.shouldAutoHighlightActiveRegion",
          "group": "navigation@1"
        },
        {
          "command": "outlinePlus.regionsView.startAutoHighlightingActiveRegion",
          "when": "view == outlinePlusRegionsView && !config.outlinePlus.regionsView.shouldAutoHighlightActiveRegion",
          "group": "navigation@1"
        },
        {
          "command": "outlinePlus.fullOutlineView.stopAutoHighlightingActiveItem",
          "when": "view == outlinePlusFullTreeView && config.outlinePlus.fullOutlineView.shouldAutoHighlightActiveItem",
          "group": "navigation@1"
        },
        {
          "command": "outlinePlus.fullOutlineView.startAutoHighlightingActiveItem",
          "when": "view == outlinePlusFullTreeView && !config.outlinePlus.fullOutlineView.shouldAutoHighlightActiveItem",
          "group": "navigation@1"
        },
        {
          "command": "outlinePlus.regionsView.expandAll",
          "when": "view == outlinePlusRegionsView",
          "group": "navigation@2"
        },
        {
          "command": "outlinePlus.fullOutlineView.expandAll",
          "when": "view == outlinePlusFullTreeView",
          "group": "navigation@2"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "outlinePlusRegionsView",
          "name": "Regions",
          "contextualTitle": "Regions",
          "when": "config.outlinePlus.regionsView.isVisible",
          "icon": "./assets/regions-view-icon.svg"
        },
        {
